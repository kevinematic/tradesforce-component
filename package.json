{
  "name": "tradesforce-external-jobs",
  "version": "1.0.0",
  "description": "Trades Force External Job Listings with Adzuna API Integration",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:netlify": "netlify dev",
    "build:frontend": "cd frontend && npm run build",
    "start:backend": "cd backend && npm start",
    "format": "prettier --write \"backend/src/**/*.{js,mjs,cjs,json}\" \"frontend/**/*.{js,jsx,css,html,json}\" \"package.json\"",
    "format:check": "prettier --check \"backend/src/**/*.{js,mjs,cjs,json}\" \"frontend/**/*.{js,jsx,css,html,json}\" \"package.json\""
  },
  "dependencies": {
    "@netlify/functions": "^2.8.2",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.8.1"
  }
}
